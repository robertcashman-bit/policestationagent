# Production Environment Variables
# Copy these to your hosting platform (Vercel, Netlify, etc.)
# Generate secrets with: openssl rand -hex 32

# Authentication Secret (min 32 chars) - used by admin and JWT
JWT_SECRET=your-secure-random-secret-key-minimum-32-characters-long

# Admin authentication - REQUIRED for production
ADMIN_SECRET=generate-a-secure-64-char-hex-with-openssl-rand-hex-32
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-secure-password-min-12-chars

# IndexNow API - set to require auth when triggering indexing
# INDEXNOW_SECRET=optional-secret-for-index-now-api

# Your website URL
NEXT_PUBLIC_SITE_URL=https://policestationagent.com

# Database (if using cloud database)
# DATABASE_URL=your-database-connection-string

# Contact form email notifications (Resend)
# Get API key from https://resend.com - required for owner notifications on form submit
RESEND_API_KEY=re_xxxxxxxxxxxx
# Email address that receives new contact form submissions
CONTACT_FORM_TO_EMAIL=your-email@example.com
# Optional: sender address (must be verified in Resend or use onboarding@resend.dev for testing)
# CONTACT_FROM_EMAIL=Police Station Agent <noreply@yourdomain.com>
