# Production Environment Variables
# Copy these to your hosting platform (Vercel, Netlify, etc.)

# Your website URL
NEXT_PUBLIC_SITE_URL=https://policestationagent.com

# Database (if using cloud database)
# DATABASE_URL=your-database-connection-string

# Contact form email notifications (Resend)
# Get API key from https://resend.com - required for owner notifications on form submit
RESEND_API_KEY=re_xxxxxxxxxxxx
# Email address that receives new contact form submissions
CONTACT_FORM_TO_EMAIL=robertdavidcashman@gmail.com
# Optional: sender address (must be verified in Resend or use onboarding@resend.dev for testing)
# CONTACT_FROM_EMAIL=Police Station Agent <noreply@policestationagent.com>

# Admin magic-code login + firm outreach (Upstash Redis required)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: extra admin emails (comma-separated). Default includes robertdavidcashman@gmail.com
# ADMIN_EMAILS=robertdavidcashman@gmail.com
CRON_SECRET=generate-with-openssl-rand-hex-32
FIRM_OUTREACH_COUNTY_ALLOWLIST=kent
FIRM_OUTREACH_FROM_EMAIL=Police Station Agent <noreply@policestationagent.com>
FIRM_OUTREACH_DIGEST_EMAIL=robertdavidcashman@gmail.com
FIRM_OUTREACH_DAILY_CAP=25
# Set true only for testing without delivering emails
# FIRM_OUTREACH_DRY_RUN=true
# Set false to disable automated sends entirely
# FIRM_OUTREACH_SEND_ENABLED=false
# Set true to pause all automated sends (admin UI can also pause via KV)
# FIRM_OUTREACH_PAUSED=true
# Master switch — set false to disable discovery/enrichment crons entirely
# FIRM_OUTREACH_ENABLED=false
# Optional: Hunter.io for paid email enrichment
# HUNTER_API_KEY=
