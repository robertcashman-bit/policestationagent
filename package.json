{
  "name": "web44ai",
  "version": "1.0.0",
  "private": true,
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 90",
    "Safari >= 14",
    "Edge >= 90",
    "iOS >= 14",
    "ChromeAndroid >= 90"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lighthouse": "node scripts/lighthouse.js",
    "scrape": "node scripts/scrape-site.js",
    "scrape:page": "node scripts/scrape-site.js --page",
    "scrape:list": "node scripts/scrape-site.js --list",
    "setup:cloudflare": "node scripts/setup-cloudflare-domain.js",
    "setup:cloudflare:auto": "node scripts/setup-cloudflare-auto.js",
    "setup:cloudflare:simple": "node scripts/setup-cloudflare-simple.js",
    "setup:domain": "node scripts/auto-setup-domain.js",
    "verify:dns": "node scripts/verify-dns-setup.js",
    "verify:blog-routes": "node scripts/verify-blog-routes.js",
    "notify:search-engines": "node scripts/notify-search-engines.js",
    "compliance:check": "node scripts/compliance-check.js",
    "compliance:scan": "node scripts/compliance-scan-and-fix.js --check",
    "compliance:fix": "node scripts/compliance-scan-and-fix.js --fix",
    "compliance:http": "node scripts/compliance-http-scan.mjs",
    "build:verified": "npm run compliance:fix && npm run compliance:scan && npm run compliance:http",
    "verify:deployment": "node scripts/verify-deployment-target.js",
    "vercel:lock": "node scripts/vercel-project-lock.mjs",
    "prebuild": "npm run vercel:lock && npm run verify:deployment"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.5.0",
    "jose": "^5.6.0",
    "jsdom": "^27.3.0",
    "lucide-react": "^0.561.0",
    "next": "^14.2.0",
    "next-auth": "^5.0.0-beta.30",
    "puppeteer": "^24.32.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.9.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/xml2js": "^0.4.14",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "glob": "^13.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
