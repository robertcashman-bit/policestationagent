{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "git": {
    "deploymentEnabled": {
      "master": true,
      "main": true,
      "feature/*": false,
      "vercel/*": false
    }
  },
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=86400"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/firm-outreach-kent-corrections",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/firm-outreach-pipeline/maintain",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/firm-outreach-enrich",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/firm-outreach-enrich",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/firm-outreach-enrich",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/firm-outreach-pipeline/full",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/firm-outreach-digest",
      "schedule": "0 17 * * *"
    }
  ]
}
