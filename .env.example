# ---------------------------------------------------------------------------
# Example environment variables for policestationagent.com
#
# Copy to `.env.local` for local development, or set these in your hosting
# platform (Vercel → Project Settings → Environment Variables).
#
# NEVER commit real secrets. This file documents shape only.
# During `next build`, CI sets SKIP_ENV_VALIDATION=true so the build works
# without secrets present (see lib/env.ts).
# ---------------------------------------------------------------------------

# --- Site -------------------------------------------------------------------
# Canonical site URL (used for metadata, sitemap, canonical links)
NEXT_PUBLIC_SITE_URL=https://policestationagent.com

# --- Email (Resend) ---------------------------------------------------------
# API key from https://resend.com — required for contact-form notifications
RESEND_API_KEY=re_xxxxxxxxxxxx
# Address that receives new contact form submissions
CONTACT_FORM_TO_EMAIL=you@example.com
# Optional verified sender (falls back to onboarding@resend.dev when unset)
# CONTACT_FROM_EMAIL=Police Station Agent <noreply@policestationagent.com>
# Optional dedicated sender for admin login codes
# ADMIN_MAGIC_FROM_EMAIL=Police Station Agent <noreply@policestationagent.com>
# Set true once the domain is verified in Resend to prefer custom senders
# RESEND_MAGIC_PREFER_CUSTOM=true
# Resend webhook signing secret from Resend dashboard or: npm run firm-outreach:configure-resend
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# --- Upstash Redis / KV (admin login + firm outreach) -----------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy aliases also supported: KV_REST_API_URL, KV_REST_API_TOKEN

# --- Cron / token signing ---------------------------------------------------
CRON_SECRET=generate-with-openssl-rand-hex-32
# Optional override for outreach decision/unsubscribe token signing
# ADMIN_DECISION_TOKEN_SECRET=generate-with-openssl-rand-hex-32

# --- Admin ------------------------------------------------------------------
# Comma-separated admin emails (defaults include robertdavidcashman@gmail.com)
# ADMIN_EMAILS=you@example.com

# --- Deployment lock --------------------------------------------------------
# Set to your Vercel project ID(s) to lock deploys (Settings → General)
# ALLOWED_VERCEL_PROJECT_IDS=prj_xxxxxxxxxxxx

# --- Firm outreach ----------------------------------------------------------
FIRM_OUTREACH_COUNTY_ALLOWLIST=kent
FIRM_OUTREACH_FROM_EMAIL=Police Station Agent <noreply@policestationagent.com>
FIRM_OUTREACH_DIGEST_EMAIL=you@example.com
# FIRM_OUTREACH_DAILY_CAP=95
# Set true to require clicking an approval email before each day's send batch (default: autosend)
# FIRM_OUTREACH_REQUIRE_APPROVAL=true
# FIRM_OUTREACH_DRY_RUN=true
# FIRM_OUTREACH_SEND_ENABLED=false
# FIRM_OUTREACH_PAUSED=true
# FIRM_OUTREACH_ENABLED=false
# HUNTER_API_KEY=

# --- Analytics --------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# GOOGLE_SITE_VERIFICATION=xxxxxxxx

# --- AI (optional chatbot/blog generation) ----------------------------------
# OPENAI_API_KEY=sk-xxxxxxxx

# --- Observability (Sentry) -------------------------------------------------
# All optional. When the DSN is unset, Sentry is a complete no-op.
# Server/edge DSN (kept private)
# SENTRY_DSN=https://xxxxxxxx@oXXXX.ingest.sentry.io/XXXX
# Browser DSN (exposed to the client; can be the same project DSN)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@oXXXX.ingest.sentry.io/XXXX
# Source map upload (build-time only; org/project/token from your Sentry account)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxx
# Optional sampling overrides (defaults to 0.1)
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
